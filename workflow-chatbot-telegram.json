              "value": "={{\n  (() => {\n  const temp = $json.body.main.temp;\n\n  const faixas = [\n    { min: -50, max: 5, icone: \"🥶\" },\n    { min: 5, max: 15, icone: \"🧥\" },\n    { min: 15, max: 20, icone: \"🌤️\" },\n    { min: 20, max: 28, icone: \"🌞\" },\n    { min: 28, max: 50, icone: \"🥵\" }\n  ];\n\n  const faixa = faixas.find(f => temp >= f.min && temp < f.max);\n\n  return `${faixa.icone}`;\n  })()\n}}",
